generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  reviewer
  admin
}

enum UserStatus {
  active
  suspended
}

enum DocumentType {
  textbook
  lecture
  past_exam
  summary_note
  exercise
  survival_kit
  other
}

enum VerificationLevel {
  unverified
  bronze
  silver
  gold
}

enum VerificationStatus {
  pending
  approved
  rejected
  changes_requested
}

enum DocumentVisibility {
  public
  private
  hidden
}

enum ReviewDecision {
  approved
  rejected
  changes_requested
}

enum ReportReason {
  inaccurate
  outdated
  copyright
  inappropriate
  spam
  other
}

enum ReportStatus {
  open
  resolved
  dismissed
}

enum ExamType {
  midterm
  final
  quiz
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String       @map("password_hash")
  fullName      String       @map("full_name")
  studentCode   String?      @map("student_code")
  institutionId String?      @map("institution_id")
  majorId       String?      @map("major_id")
  role          UserRole     @default(student)
  status        UserStatus   @default(active)
  institution   Institution? @relation(fields: [institutionId], references: [id])
  major         Major?       @relation(fields: [majorId], references: [id])
  documents     Document[]   @relation("UploadedDocuments")
  reviews       DocumentReview[] @relation("DocumentReviews")
  ratings       DocumentRating[]
  comments      DocumentComment[]
  reports       DocumentReport[]
  enrollments   CourseEnrollment[]
  auditLogs     AuditLog[]    @relation("ActorAuditLogs")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([institutionId])
  @@index([majorId])
  @@map("users")
}

model Institution {
  id          String     @id @default(cuid())
  name        String
  code        String?    @unique
  description String?    @db.Text
  majors      Major[]
  users       User[]
  documents   Document[]
  instructors Instructor[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("institutions")
}

model Major {
  id            String       @id @default(cuid())
  institutionId String?      @map("institution_id")
  code          String?
  name          String
  description   String?      @db.Text
  institution   Institution? @relation(fields: [institutionId], references: [id])
  users         User[]
  subjects      Subject[]
  documents     Document[]
  instructors   Instructor[]
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@unique([institutionId, code])
  @@index([institutionId])
  @@map("majors")
}

model Subject {
  id          String     @id @default(cuid())
  majorId     String?    @map("major_id")
  code        String?
  name        String
  description String?    @db.Text
  major       Major?     @relation(fields: [majorId], references: [id])
  documents   Document[]
  exams       Exam[]
  enrollments CourseEnrollment[]
  instructors Instructor[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([majorId, code])
  @@index([majorId])
  @@map("subjects")
}

model Document {
  id                 String               @id @default(cuid())
  title              String
  description        String?              @db.Text
  authorName         String?              @map("author_name")
  uploaderId         String?              @map("uploader_id")
  institutionId      String?              @map("institution_id")
  majorId            String?              @map("major_id")
  subjectId          String?              @map("subject_id")
  instructorName     String?              @map("instructor_name")
  termLabel          String?              @map("term_label")
  examName           String?              @map("exam_name")
  tags               Json?
  documentType       DocumentType         @default(other) @map("document_type")
  year               Int?
  pages              Int?
  language           String               @default("vi")
  fileUrl            String?              @map("file_url")
  thumbnailUrl       String?              @map("thumbnail_url")
  fileSize           Int?                 @map("file_size")
  mimeType           String?              @map("mime_type")
  verificationLevel  VerificationLevel    @default(unverified) @map("verification_level")
  verificationStatus VerificationStatus   @default(pending) @map("verification_status")
  visibility         DocumentVisibility   @default(public)
  ratingAvg          Decimal              @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount        Int                  @default(0) @map("rating_count")
  viewCount          Int                  @default(0) @map("view_count")
  downloadCount      Int                  @default(0) @map("download_count")
  uploader           User?                @relation("UploadedDocuments", fields: [uploaderId], references: [id])
  institution        Institution?         @relation(fields: [institutionId], references: [id])
  major              Major?               @relation(fields: [majorId], references: [id])
  subject            Subject?             @relation(fields: [subjectId], references: [id])
  reviewHistory      DocumentReview[]
  ratings            DocumentRating[]
  comments           DocumentComment[]
  reports            DocumentReport[]
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@index([subjectId, verificationLevel, visibility])
  @@index([majorId, documentType, visibility])
  @@index([createdAt])
  @@index([ratingAvg, ratingCount])
  @@index([downloadCount])
  @@index([uploaderId])
  @@map("documents")
}

model DocumentReview {
  id                String            @id @default(cuid())
  documentId        String            @map("document_id")
  reviewerId        String            @map("reviewer_id")
  decision          ReviewDecision
  verificationLevel VerificationLevel @default(unverified) @map("verification_level")
  note              String?           @db.Text
  document          Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reviewer          User              @relation("DocumentReviews", fields: [reviewerId], references: [id], onDelete: Restrict)
  createdAt         DateTime          @default(now()) @map("created_at")

  @@index([documentId, createdAt])
  @@index([reviewerId, createdAt])
  @@index([decision])
  @@map("document_reviews")
}

model DocumentRating {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  userId     String   @map("user_id")
  rating     Int
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
  @@map("document_ratings")
}

model DocumentComment {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  userId     String   @map("user_id")
  content    String   @db.Text
  isHidden   Boolean  @default(false) @map("is_hidden")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([documentId, isHidden, createdAt])
  @@index([userId])
  @@map("document_comments")
}

model DocumentReport {
  id         String       @id @default(cuid())
  documentId String       @map("document_id")
  reporterId String       @map("reporter_id")
  reason     ReportReason
  detail     String?      @db.Text
  status     ReportStatus @default(open)
  document   Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@index([documentId, status])
  @@index([reporterId, status])
  @@map("document_reports")
}

model Exam {
  id          String     @id @default(cuid())
  subjectId   String     @map("subject_id")
  name        String
  examType    ExamType   @map("exam_type")
  examDate    DateTime   @map("exam_date")
  termLabel   String?    @map("term_label")
  location    String?
  subject     Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([subjectId, examDate])
  @@index([examType, examDate])
  @@map("exams")
}

model CourseEnrollment {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  subjectId            String   @map("subject_id")
  termLabel            String?  @map("term_label")
  emailReminderEnabled Boolean  @default(true) @map("email_reminder_enabled")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject              Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([userId, subjectId])
  @@index([subjectId])
  @@map("course_enrollments")
}

model Instructor {
  id            String       @id @default(cuid())
  institutionId String?      @map("institution_id")
  majorId       String?      @map("major_id")
  subjectId     String?      @map("subject_id")
  fullName      String       @map("full_name")
  title         String?
  email         String?
  bio           String?      @db.Text
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  major         Major?       @relation(fields: [majorId], references: [id], onDelete: SetNull)
  subject       Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@unique([subjectId, fullName])
  @@index([institutionId])
  @@index([majorId])
  @@index([subjectId])
  @@map("instructors")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  actor      User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}
